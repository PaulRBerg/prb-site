---
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import Tag from "@/components/Tag.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import SiteShell from "@/layouts/SiteShell.astro";
import { getPath } from "@/utils/getPath";
import { getTagSlug } from "@/utils/blog";
import { getPostTransitionName } from "@/utils/postPresentation";
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
}

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initialOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
} = post.data;

const { Content } = await render(post);

let ogImageUrl: string | undefined;
if (typeof initialOgImage === "string") {
  ogImageUrl = initialOgImage;
} else if (initialOgImage?.src) {
  ogImageUrl = initialOgImage.src;
}

if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}/index.png`;
}

const ogImage = ogImageUrl ? new URL(ogImageUrl, Astro.url.origin).href : undefined;
const pageURL = new URL(
  canonicalURL ?? getPath(post.id, post.filePath),
  Astro.site ?? Astro.url.origin,
).toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  author: [
    {
      "@type": "Person",
      name: author,
      ...(SITE.profile && { url: SITE.profile }),
    },
  ],
  datePublished: pubDatetime.toISOString(),
  description,
  headline: title,
  keywords: tags,
  mainEntityOfPage: pageURL,
  ...(modDatetime && { dateModified: modDatetime.toISOString() }),
  ...(ogImage && { image: ogImage }),
};

const layoutProps = {
  author,
  canonicalURL,
  description,
  modDatetime,
  ogImage,
  pubDatetime,
  scrollSmooth: true,
  structuredData,
  title: `${title} | ${SITE.title}`,
};

const allPosts = posts.map(({ data: { title: postTitle }, id, filePath }) => ({
  filePath,
  id,
  title: postTitle,
}));

const currentPostIndex = allPosts.findIndex((entry) => entry.id === post.id);
const prevPost = currentPostIndex > 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost = currentPostIndex < allPosts.length - 1 ? allPosts[currentPostIndex + 1] : null;
---

<SiteShell {...layoutProps}>
  <div
    aria-hidden="true"
    data-post-progress
    class="pointer-events-none fixed inset-x-0 top-0 z-[100] h-1 overflow-hidden bg-background opacity-0 transition-opacity duration-150"
  >
    <div
      data-post-progress-bar
      class="h-full w-0 bg-accent transition-[width] duration-100 ease-out"
    >
    </div>
  </div>
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={getPostTransitionName(title)}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        aria-hidden="true"
        class:list={["max-sm:hidden", { hidden: !SITE.editPost.enabled || hideEditPost }]}
      >
        |
      </span>
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map((tag) => <Tag tag={getTagSlug(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />
    <ShareLinks />

    <hr class="my-6 border-dashed" />

    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>Previous Post</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>Next Post</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
</SiteShell>

<script is:inline data-astro-rerun>
  (() => {
    const noop = () => null;

    const setupScrollProgress = () => {
      const progressTrack = document.querySelector("[data-post-progress]");
      const progressBar = document.querySelector("[data-post-progress-bar]");

      if (!progressTrack || !progressBar) {
        return noop;
      }

      let frameId = 0;
      const syncProgress = () => {
        frameId = 0;

        const scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
        const scrollHeight =
          document.documentElement.scrollHeight - document.documentElement.clientHeight;
        const progress = scrollHeight > 0 ? Math.min(scrollTop / scrollHeight, 1) : 0;

        progressBar.style.width = `${progress * 100}%`;
        progressTrack.classList.toggle("opacity-0", progress === 0);
        progressTrack.classList.toggle("opacity-100", progress > 0);
      };

      const queueSync = () => {
        if (frameId !== 0) {
          return;
        }

        frameId = window.requestAnimationFrame(syncProgress);
      };

      window.addEventListener("scroll", queueSync, { passive: true });
      window.addEventListener("resize", queueSync);
      queueSync();

      return () => {
        if (frameId !== 0) {
          window.cancelAnimationFrame(frameId);
        }

        window.removeEventListener("scroll", queueSync);
        window.removeEventListener("resize", queueSync);
      };
    };

    const addHeadingLinks = () => {
      const headings = [
        ...document.querySelectorAll("article h2, article h3, article h4, article h5, article h6"),
      ];
      for (const heading of headings) {
        if (!heading.id || heading.querySelector(".heading-link")) {
          continue;
        }

        heading.classList.add("group");
        const link = document.createElement("a");
        link.className =
          "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
        link.href = `#${heading.id}`;

        const span = document.createElement("span");
        span.ariaHidden = "true";
        span.textContent = "#";
        link.append(span);
        heading.append(link);
      }
    };

    const attachCopyButtons = () => {
      const copyButtonLabel = "Copy";
      const copyCode = async (block, button) => {
        const code = block.querySelector("code");
        const text = code?.textContent;

        await navigator.clipboard.writeText(text ?? "");
        button.textContent = "Copied";

        setTimeout(() => {
          button.textContent = copyButtonLabel;
        }, 700);
      };

      const codeBlocks = [...document.querySelectorAll("article pre")];
      for (const codeBlock of codeBlocks) {
        if (codeBlock.dataset.copyBound === "true") {
          continue;
        }

        const wrapper = document.createElement("div");
        wrapper.dataset.copyWrapper = "true";
        wrapper.style.position = "relative";

        const computedStyle = getComputedStyle(codeBlock);
        const hasFileNameOffset =
          computedStyle.getPropertyValue("--file-name-offset").trim() !== "";
        const topClass = hasFileNameOffset ? "top-(--file-name-offset)" : "-top-3";

        const copyButton = document.createElement("button");
        copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
        copyButton.textContent = copyButtonLabel;
        codeBlock.dataset.copyBound = "true";
        codeBlock.setAttribute("tabindex", "0");
        codeBlock.append(copyButton);

        codeBlock.parentNode?.insertBefore(wrapper, codeBlock);
        wrapper.append(codeBlock);

        copyButton.addEventListener("click", async () => {
          await copyCode(codeBlock, copyButton);
        });
      }
    };

    const cleanupScrollProgress = setupScrollProgress();
    addHeadingLinks();
    attachCopyButtons();

    document.addEventListener(
      "astro:before-swap",
      () => {
        cleanupScrollProgress();
      },
      { once: true },
    );

    document.addEventListener(
      "astro:after-swap",
      () => {
        window.scrollTo({ behavior: "instant", left: 0, top: 0 });
      },
      { once: true },
    );
  })();
</script>
