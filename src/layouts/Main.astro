---
import { SITE } from "@/config";

interface StringTitle {
  pageTitle: string;
}
interface ArrayTitle {
  pageTitle: [string, string];
  titleTransition: string;
}

type Props = (StringTitle | ArrayTitle) & { pageDesc?: string };

const { props } = Astro;

const backUrl = SITE.showBackButton ? Astro.url.pathname : "/";
---

<main data-back-url={backUrl} id="main-content" class="app-layout pb-4">
  {
    "titleTransition" in props ? (
      <h1 class="mt-8 text-2xl font-semibold sm:text-3xl">
        {props.pageTitle[0]}
        <span transition:name={props.titleTransition}>{props.pageTitle[1]}</span>
      </h1>
    ) : (
      <h1 class="mt-8 text-2xl font-semibold sm:text-3xl">{props.pageTitle}</h1>
    )
  }
  <p class="mt-2 mb-6 italic">{props.pageDesc}</p>
  <slot />
</main>
